{
  "name": "Introduction to error handling",
  "description": "This playbook demonstrates how users can enable 'continue on failure' from the action execution settings in Fusion SOAR, allowing workflows to maintain continuity when an action fails. Instead of the entire workflow failing, the workflow continues to the next node based on your defined error handling configuration, enabling you to add conditional branches to handle errors and implement resilient workflows that gracefully adapt to failures rather than stopping completely.",
  "model": {
    "trigger": {
      "name": "On demand",
      "outgoing_flow": "FROM_trigger_TO_ExampleForErrorHandling",
      "trigger_type": "On demand"
    },
    "flows": {
      "FROM_ActionFailed_TO_end": {
        "source": "ActionFailed",
        "target": "end",
        "condition": {}
      },
      "FROM_ExampleForErrorHandling_TO_data39workflow_execution_errors39_size__0": {
        "source": "ExampleForErrorHandling",
        "target": "data39workflow_execution_errors39_size__0",
        "condition": {}
      },
      "FROM_PrintIfActionSuccessfullyReturnsData_TO_end": {
        "source": "PrintIfActionSuccessfullyReturnsData",
        "target": "end",
        "condition": {}
      },
      "FROM_data39workflow_execution_errors39_size__0_TO_PrintIfActionSuccessfullyReturnsData": {
        "source": "data39workflow_execution_errors39_size__0",
        "target": "PrintIfActionSuccessfullyReturnsData",
        "condition": {
          "cel_expression": "data['Workflow.Execution.Errors'].size() == 0",
          "display": [
            "data[&#39;Workflow.Execution.Errors&#39;].size() == 0"
          ]
        }
      },
      "FROM_data39workflow_execution_errors39_size_gt_0_TO_ActionFailed": {
        "source": "data39workflow_execution_errors39_size__0",
        "target": "ActionFailed",
        "condition": {
          "cel_expression": "data['Workflow.Execution.Errors'].size() > 0",
          "display": [
            "data[&#39;Workflow.Execution.Errors&#39;].size() &gt; 0"
          ]
        }
      },
      "FROM_trigger_TO_ExampleForErrorHandling": {
        "source": "trigger",
        "target": "ExampleForErrorHandling",
        "condition": {}
      }
    },
    "gateways": {
      "data39workflow_execution_errors39_size__0": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_ExampleForErrorHandling_TO_data39workflow_execution_errors39_size__0"
          ],
          "outgoing": [
            "FROM_data39workflow_execution_errors39_size__0_TO_PrintIfActionSuccessfullyReturnsData",
            "FROM_data39workflow_execution_errors39_size_gt_0_TO_ActionFailed"
          ]
        }
      }
    },
