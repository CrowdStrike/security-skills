{
  "name": "Identity Detection Auto-Resolution - Recent Password Change",
  "description": "This workflow automatically resolves Identity Protection Password Brute Force detections when the involved user has recently changed their password within 30 minutes of the detection trigger time. The logic assumes that recent password changes indicate legitimate user activity, making the alert a likely false positive.\n\nNote: The 30-minute time window can be customized based on your organization's needs",
  "labels": [
    "Identity Protection"
  ],
  "model": {
    "trigger": {
      "id": "002a46effd4c30ba51dcb1465b066842",
      "name": "Detection > Identity Detection",
      "outgoing_flow": "FROM_trigger_TO_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a",
      "trigger_type": "Signal",
      "version_constraint": "~0"
    },
    "flows": {
      "FROM_add_comment_to_alert_d0f89df5_TO_end": {
        "source": "add_comment_to_alert_d0f89df5",
        "target": "end",
        "condition": {}
      },
      "FROM_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0_TO_set_alert_status_0e01213e": {
        "source": "cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0",
        "target": "set_alert_status_0e01213e",
        "condition": {
          "cel_expression": "cs.timestamp.parse(data['Trigger.Category.Investigatable.Product.IDP.EndTime'], 'RFC3339') - cs.timestamp.parse(data['get_user_identity_context_36d2cf6c.PasswordChange'], 'RFC3339') < duration('30m')",
          "display": [
            "cs.timestamp.parse(data[&#39;Trigger.Category.Investigatable.Product.IDP.EndTime&#39;], &#39;RFC3339&#39;) - cs.timestamp.parse(data[&#39;activity_36d2cf6c-0585-4be2-8713-03ec9642dc92.PasswordChange&#39;], &#39;RFC3339&#39;) &lt; duration(&#39;30m&#39;)"
          ]
        }
      },
      "FROM_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a_TO_get_user_identity_context_36d2cf6c": {
        "source": "detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a",
        "target": "get_user_identity_context_36d2cf6c",
        "condition": {
          "expression": "Trigger.Category.Investigatable.Product.IDP.DetectName:['Password Brute Force attack (Active Directory)','Password Brute Force attack (web-based)']",
          "display": [
            "Detection name includes Password Brute Force attack (Active Directory), Password Brute Force attack (web-based)"
          ]
        }
      },
      "FROM_get_user_identity_context_36d2cf6c_TO_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0": {
        "source": "get_user_identity_context_36d2cf6c",
        "target": "cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0",
        "condition": {}
      },
      "FROM_set_alert_status_0e01213e_TO_add_comment_to_alert_d0f89df5": {
        "source": "set_alert_status_0e01213e",
        "target": "add_comment_to_alert_d0f89df5",
        "condition": {}
      },
      "FROM_trigger_TO_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a": {
        "source": "trigger",
        "target": "detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a",
        "condition": {}
      }
    },
    "gateways": {
      "cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_get_user_identity_context_36d2cf6c_TO_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0"
          ],
          "outgoing": [
            "FROM_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0_TO_set_alert_status_0e01213e"
          ]
        }
      },
      "detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_trigger_TO_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a"
          ],
          "outgoing": [
            "FROM_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a_TO_get_user_identity_context_36d2cf6c"
          ]
        }
      }
    },
    "activities": {
      "add_comment_to_alert_d0f89df5": {
        "id": "7b77cb5d5ff2651cc51c7c4c610d54d1",
        "name": "Add comment to detection",
        "flows": {
          "incoming": "FROM_set_alert_status_0e01213e_TO_add_comment_to_alert_d0f89df5",
          "outgoing": "FROM_add_comment_to_alert_d0f89df5_TO_end"
        },
        "properties": {
          "_fields": [
            "${get_user_identity_context_36d2cf6c.EntityName}",
            "${get_user_identity_context_36d2cf6c.PasswordChange}"
          ],
          "comment": "Detection auto-resolved: user changed password shortly before detection triggered",
          "investigatable_id": "${Trigger.Category.Investigatable.InvestigatableID}"
        },
        "version_constraint": "~0"
      },
      "get_user_identity_context_36d2cf6c": {
        "id": "19c7e2af0a24f468be7797fe180c8329",
        "name": "Get user identity context",
        "flows": {
          "incoming": "FROM_detection_name_includes_password_brute_force_attack_active_directory_password_brute_force_attack_web_5044841a_TO_get_user_identity_context_36d2cf6c",
          "outgoing": "FROM_get_user_identity_context_36d2cf6c_TO_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0"
        },
        "properties": {
          "continue_if_entity_not_found": false,
          "entity_sid": "${Trigger.Category.Investigatable.Product.IDP.SourceAccountObjectSid}",
          "username": "${Trigger.Category.Investigatable.Product.IDP.SourceAccountName}"
        },
        "version_constraint": "~1"
      },
      "set_alert_status_0e01213e": {
        "id": "beb56cc40d334583671ca91e6e390056",
        "name": "Set detection status",
        "flows": {
          "incoming": "FROM_cs_timestamp_parsedata39trigger_category_investigatable_product_idp_endtime39_39rfc333939___cs_times_449392c0_TO_set_alert_status_0e01213e",
          "outgoing": "FROM_set_alert_status_0e01213e_TO_add_comment_to_alert_d0f89df5"
        },
        "properties": {
          "investigatable_id": "${Trigger.Category.Investigatable.InvestigatableID}",
          "status": "closed"
        }
      }
    },
    "end": {
      "incoming_flows": [
        "FROM_add_comment_to_alert_d0f89df5_TO_end"
      ]
    }
  },
  "use_cases": [
    "Identity & Access"
  ],
  "vendors": [
    "CrowdStrike"
  ],
  "complexity": 3,
  "trigger_type": "Event",
  "id": "a3df411d08c3488e9a4a7490b3eead63",
