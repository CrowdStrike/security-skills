{
  "name": "Domain Enrichment VirusTotal",
  "description": "Enriches domains with threat intelligence data from VirusTotal, including malicious/harmless voting statistics, registrar information, creation dates, and DNS resolution history with associated IP addresses. This playbook can be triggered on-demand from a Next-Gen SIEM Case or integrated into other automated playbooks to perform enrichment when provided a detection ID and the relevant entity (such as IP addresses, domains, URLs, or file hashes).",
  "model": {
    "trigger": {
      "name": "On demand",
      "outgoing_flow": "FROM_trigger_TO_domain_exists",
      "parameters": {
        "properties": {
          "case_id": {
            "type": "string",
            "title": "Case ID",
            "format": "ngsiemCaseID"
          },
          "detection_id": {
            "type": "string",
            "title": "Detection ID",
            "format": "investigatableID"
          },
          "domain": {
            "type": "string",
            "title": "Domain",
            "format": "domain"
          }
        },
        "type": "object"
      },
      "trigger_type": "On demand"
    },
    "flows": {
      "FROM_AddCommentToAlertFinalEnrichmentComments_TO_end": {
        "source": "AddCommentToAlertFinalEnrichmentComments",
        "target": "end",
        "condition": {}
      },
      "FROM_AddCommentToCaseEnrichmentComments_TO_end": {
        "source": "AddCommentToCaseEnrichmentComments",
        "target": "end",
        "condition": {}
      },
      "FROM_AddTagsToCase_TO_end": {
        "source": "AddTagsToCaseEnrichmentTags",
        "target": "end",
        "condition": {}
      },
      "FROM_CreateVariable2_TO_UpdateVariableParseCommentChunkingVars": {
        "source": "CreateVariableInitializeCommentChunkingVars",
        "target": "UpdateVariableParseCommentChunkingVars",
        "condition": {}
      },
      "FROM_CreateVariable3_TO_UpdateVariable5": {
        "source": "CreateVariable3",
        "target": "UpdateVariable5",
        "condition": {}
      },
      "FROM_CreateVariable_TO_CreateVariable3": {
        "source": "CreateVariable",
        "target": "CreateVariable3",
        "condition": {}
      },
      "FROM_Loop1_TO_data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current": {
        "source": "Loop1",
        "target": "data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current",
        "condition": {}
      },
      "FROM_Loop2_TO_UpdateVariable8": {
        "source": "Loop2",
        "target": "UpdateVariable8",
        "condition": {}
      },
      "FROM_Loop_TO_end": {
        "source": "Loop",
        "target": "end",
        "condition": {}
      },
      "FROM_UpdateVariable5_TO_VirusTotalDomainLookup": {
        "source": "UpdateVariable5",
        "target": "VirusTotalDomainLookup",
        "condition": {}
      },
      "FROM_UpdateVariable6_TO_UpdateVariable7": {
        "source": "UpdateVariable6",
        "target": "UpdateVariable7",
        "condition": {}
      },
      "FROM_UpdateVariable7_TO_Loop2": {
        "source": "UpdateVariable7",
        "target": "Loop2",
        "condition": {}
      },
      "FROM_UpdateVariable8_TO_UpdateVariable9": {
        "source": "UpdateVariable8",
        "target": "UpdateVariable9",
        "condition": {}
      },
      "FROM_UpdateVariable9_TO_UpdateVariableSetEnrichmentCommentAndTags": {
        "source": "UpdateVariable9",
        "target": "UpdateVariableSetEnrichmentCommentAndTags",
        "condition": {}
      },
      "FROM_UpdateVariableParseCommentChunkingVars_TO_Loop1": {
        "source": "UpdateVariableParseCommentChunkingVars",
        "target": "Loop1",
        "condition": {}
      },
      "FROM_UpdateVariableSetEnrichmentCommentAndTags_TO_parallel_UpdateVariableSetEnrichmentCommentAndTags": {
        "source": "UpdateVariableSetEnrichmentCommentAndTags",
        "target": "parallel_UpdateVariableSetEnrichmentCommentAndTags",
        "condition": {}
      },
      "FROM_VirusTotalDomainLookup_TO_status_code_is_equal_to_200___ok": {
        "source": "VirusTotalDomainLookup",
        "target": "status_code_is_equal_to_200___ok",
        "condition": {}
      },
      "FROM_WriteToLogRepo_TO_end": {
        "source": "WriteToLogRepo",
        "target": "end",
        "condition": {}
      },
      "FROM_case_id_exists_TO_parallel_case_id_exists": {
        "source": "case_id_exists",
        "target": "parallel_case_id_exists",
        "condition": {
          "expression": "case_id:!null",
          "display": [
            "Case ID exists"
          ]
        }
      },
      "FROM_data39workflowcustomvariable_comment39_size_gt_0_TO_AddCommentToCaseEnrichmentComments": {
        "source": "data39workflowcustomvariable_comment39_size_gt_0",
        "target": "AddCommentToCaseEnrichmentComments",
        "condition": {
          "cel_expression": "data['WorkflowCustomVariable.comment'].size() > 0",
          "display": [
            "data[&#39;WorkflowCustomVariable.comment&#39;].size() &gt; 0"
          ]
        }
      },
      "FROM_data39workflowcustomvariable_comment39_size_gt_1_TO_CreateVariable2": {
        "source": "data39workflowcustomvariable_comment39_size_gt_1",
        "target": "CreateVariableInitializeCommentChunkingVars",
        "condition": {
          "cel_expression": "data['WorkflowCustomVariable.comment'].size() > 0",
          "display": [
            "data[&#39;WorkflowCustomVariable.comment&#39;].size() &gt; 0"
          ]
        }
      },
      "FROM_data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current_TO_AddCommentToAlertFinalEnrichmentComments": {
        "source": "data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current",
        "target": "AddCommentToAlertFinalEnrichmentComments",
        "condition": {
          "cel_expression": "data['WorkflowCustomVariable.current_comment'].size() > 0 && data['WorkflowCustomVariable.current_comment'].trim().size() != data['WorkflowCustomVariable.common_line'].trim().size()",
          "display": [
            "data[&#39;WorkflowCustomVariable.current_comment&#39;].size() &gt; 0 &amp;&amp; data[&#39;WorkflowCustomVariable.current_comment&#39;].trim().size() != data[&#39;WorkflowCustomVariable.common_line&#39;].trim().size()"
          ]
        }
      },
      "FROM_data39workflowcustomvariable_tags39_size_gt_0_TO_AddTagsToCase": {
        "source": "data39workflowcustomvariable_tags39_size_gt_0",
        "target": "AddTagsToCaseEnrichmentTags",
        "condition": {
          "cel_expression": "data['WorkflowCustomVariable.tags'].size() > 0",
          "display": [
            "data[&#39;WorkflowCustomVariable.tags&#39;].size() &gt; 0"
          ]
        }
      },
      "FROM_data39workflowcustomvariable_tags39_size_gt_1_TO_Loop": {
        "source": "data39workflowcustomvariable_tags39_size_gt_1",
        "target": "Loop",
        "condition": {
          "cel_expression": "data['WorkflowCustomVariable.tags'].size() > 0",
          "display": [
            "data[&#39;WorkflowCustomVariable.tags&#39;].size() &gt; 0"
          ]
        }
      },
      "FROM_detection_id_exists_TO_parallel_detection_id_exists": {
        "source": "detection_id_exists",
        "target": "parallel_detection_id_exists",
        "condition": {
          "expression": "detection_id:!null",
          "display": [
            "Detection ID exists"
          ]
        }
      },
      "FROM_domain_exists_TO_CreateVariable": {
        "source": "domain_exists",
        "target": "CreateVariable",
        "condition": {
          "expression": "domain:!null",
          "display": [
            "Domain exists"
          ]
        }
      },
      "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_case_id_exists": {
        "source": "parallel_UpdateVariableSetEnrichmentCommentAndTags",
        "target": "case_id_exists",
        "condition": {}
      },
      "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_detection_id_exists": {
        "source": "parallel_UpdateVariableSetEnrichmentCommentAndTags",
        "target": "detection_id_exists",
        "condition": {}
      },
      "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_0": {
        "source": "parallel_case_id_exists",
        "target": "data39workflowcustomvariable_comment39_size_gt_0",
        "condition": {}
      },
      "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_0": {
        "source": "parallel_case_id_exists",
        "target": "data39workflowcustomvariable_tags39_size_gt_0",
        "condition": {}
      },
      "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_1": {
        "source": "parallel_detection_id_exists",
        "target": "data39workflowcustomvariable_comment39_size_gt_1",
        "condition": {}
      },
      "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_1": {
        "source": "parallel_detection_id_exists",
        "target": "data39workflowcustomvariable_tags39_size_gt_1",
        "condition": {}
      },
      "FROM_status_code_is_equal_to_200___ok_TO_UpdateVariable6": {
        "source": "status_code_is_equal_to_200___ok",
        "target": "UpdateVariable6",
        "condition": {
          "expression": "VirusTotalDomainLookup.status_code:200",
          "display": [
            "Status code is equal to 200 - OK"
          ]
        }
      },
      "FROM_status_code_is_equal_to_200___ok_TO_WriteToLogRepo": {
        "source": "status_code_is_equal_to_200___ok",
        "target": "WriteToLogRepo",
        "condition": {}
      },
      "FROM_trigger_TO_domain_exists": {
        "source": "trigger",
        "target": "domain_exists",
        "condition": {}
      }
    },
    "gateways": {
      "case_id_exists": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_case_id_exists"
          ],
          "outgoing": [
            "FROM_case_id_exists_TO_parallel_case_id_exists"
          ]
        }
      },
      "data39workflowcustomvariable_comment39_size_gt_0": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_0"
          ],
          "outgoing": [
            "FROM_data39workflowcustomvariable_comment39_size_gt_0_TO_AddCommentToCaseEnrichmentComments"
          ]
        }
      },
      "data39workflowcustomvariable_comment39_size_gt_1": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_1"
          ],
          "outgoing": [
            "FROM_data39workflowcustomvariable_comment39_size_gt_1_TO_CreateVariable2"
          ]
        }
      },
      "data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_Loop1_TO_data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current"
          ],
          "outgoing": [
            "FROM_data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current_TO_AddCommentToAlertFinalEnrichmentComments"
          ]
        }
      },
      "data39workflowcustomvariable_tags39_size_gt_0": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_0"
          ],
          "outgoing": [
            "FROM_data39workflowcustomvariable_tags39_size_gt_0_TO_AddTagsToCase"
          ]
        }
      },
      "data39workflowcustomvariable_tags39_size_gt_1": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_1"
          ],
          "outgoing": [
            "FROM_data39workflowcustomvariable_tags39_size_gt_1_TO_Loop"
          ]
        }
      },
      "detection_id_exists": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_detection_id_exists"
          ],
          "outgoing": [
            "FROM_detection_id_exists_TO_parallel_detection_id_exists"
          ]
        }
      },
      "domain_exists": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_trigger_TO_domain_exists"
          ],
          "outgoing": [
            "FROM_domain_exists_TO_CreateVariable"
          ]
        }
      },
      "parallel_UpdateVariableSetEnrichmentCommentAndTags": {
        "type": "parallel",
        "flows": {
          "incoming": [
            "FROM_UpdateVariableSetEnrichmentCommentAndTags_TO_parallel_UpdateVariableSetEnrichmentCommentAndTags"
          ],
          "outgoing": [
            "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_case_id_exists",
            "FROM_parallel_UpdateVariableSetEnrichmentCommentAndTags_TO_detection_id_exists"
          ]
        }
      },
      "parallel_case_id_exists": {
        "type": "parallel",
        "flows": {
          "incoming": [
            "FROM_case_id_exists_TO_parallel_case_id_exists"
          ],
          "outgoing": [
            "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_0",
            "FROM_parallel_case_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_0"
          ]
        }
      },
      "parallel_detection_id_exists": {
        "type": "parallel",
        "flows": {
          "incoming": [
            "FROM_detection_id_exists_TO_parallel_detection_id_exists"
          ],
          "outgoing": [
            "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_tags39_size_gt_1",
            "FROM_parallel_detection_id_exists_TO_data39workflowcustomvariable_comment39_size_gt_1"
          ]
        }
      },
      "status_code_is_equal_to_200___ok": {
        "type": "exclusive",
        "flows": {
          "incoming": [
            "FROM_VirusTotalDomainLookup_TO_status_code_is_equal_to_200___ok"
          ],
          "outgoing": [
            "FROM_status_code_is_equal_to_200___ok_TO_UpdateVariable6",
            "FROM_status_code_is_equal_to_200___ok_TO_WriteToLogRepo"
          ],
          "default": "FROM_status_code_is_equal_to_200___ok_TO_WriteToLogRepo"
        }
      }
    },
    "activities": {
      "AddCommentToAlertFinalEnrichmentComments": {
        "id": "7b77cb5d5ff2651cc51c7c4c610d54d1",
        "name": "Add comment to alert - Final enrichment comments",
        "flows": {
          "incoming": "FROM_data39workflowcustomvariable_current_comment39_size_gt_0_ampamp_data39workflowcustomvariable_current_TO_AddCommentToAlertFinalEnrichmentComments",
          "outgoing": "FROM_AddCommentToAlertFinalEnrichmentComments_TO_end"
        },
        "mock_output": {
          "node_mock_id": "",
          "enabled": false
        },
        "properties": {
          "comment": "${data['WorkflowCustomVariable.current_comment']}",
          "investigatable_id": "${detection_id}"
        },
        "version_constraint": "~0"
      },
      "AddCommentToCaseEnrichmentComments": {
        "id": "a16f4fdd1b244b0bfeecd47e25dbe0e0",
        "name": "Add Comment to Case - Enrichment comments",
        "flows": {
          "incoming": "FROM_data39workflowcustomvariable_comment39_size_gt_0_TO_AddCommentToCaseEnrichmentComments",
          "outgoing": "FROM_AddCommentToCaseEnrichmentComments_TO_end"
        },
        "mock_output": {
          "node_mock_id": "",
          "enabled": false
        },
        "properties": {
          "case_id": "${case_id}",
          "comment": "${data['WorkflowCustomVariable.comment'].replace('|~|', '')}"
        },
        "version_constraint": "~1"
      },
      "AddTagsToCaseEnrichmentTags": {
        "id": "696f57b7cdcd475e5c56e6196836ee39",
        "name": "Add tags to case - Enrichment tags",
        "flows": {
          "incoming": "FROM_data39workflowcustomvariable_tags39_size_gt_0_TO_AddTagsToCase",
          "outgoing": "FROM_AddTagsToCase_TO_end"
        },
        "mock_output": {
          "node_mock_id": "",
          "enabled": false
        },
        "properties": {
          "case_id": "${case_id}",
          "tags": [
            "${data['WorkflowCustomVariable.tags']}"
          ]
        },
        "version_constraint": "~1"
      },
      "CreateVariable": {
        "id": "702d15788dbbffdf0b68d8e2f3599aa4",
        "class": "CreateVariable",
        "name": "Create variable - Initialize comment and tags storage",
        "flows": {
          "incoming": "FROM_domain_exists_TO_CreateVariable",
          "outgoing": "FROM_CreateVariable_TO_CreateVariable3"
        },
        "properties": {
          "variable_schema": {
            "properties": {
              "comment": {
                "type": "string"
              },
              "tags": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "type": "object"
          }
        },
        "version_constraint": "~1"
      },
      "CreateVariable3": {
        "id": "702d15788dbbffdf0b68d8e2f3599aa4",
        "class": "CreateVariable",
        "name": "Create variable - Initialize DNS resolution data structure",
        "flows": {
          "incoming": "FROM_CreateVariable_TO_CreateVariable3",
          "outgoing": "FROM_CreateVariable3_TO_UpdateVariable5"
        },
        "properties": {
          "variable_schema": {
            "properties": {
              "cleaned_domain": {
                "type": "string"
              },
              "dns_res": {
                "items": {
                  "properties": {},
                  "type": "object"
                },
                "type": "array"
              },
              "loop_output": {
                "items": {
                  "properties": {},
                  "type": "object"
                },
                "type": "array"
              },
              "resolution_ids": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "type": "object"
          }
        },
        "version_constraint": "~1"
      },
      "CreateVariableInitializeCommentChunkingVars": {
        "id": "702d15788dbbffdf0b68d8e2f3599aa4",
        "class": "CreateVariable",
        "name": "Create variable - Initialize comment chunking vars",
        "flows": {
          "incoming": "FROM_data39workflowcustomvariable_comment39_size_gt_1_TO_CreateVariable2",
          "outgoing": "FROM_CreateVariable2_TO_UpdateVariableParseCommentChunkingVars"
        },
        "mock_output": {
          "node_mock_id": "",
          "enabled": false
        },
        "properties": {
          "variable_schema": {
            "properties": {
              "common_line": {
                "type": "string"
              },
              "current_comment": {
                "type": "string"
              },
              "current_index": {
                "type": "integer"
              },
              "field_and_value_array": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "type": "object"
          }
        },
        "version_constraint": "~1"
      },
      "UpdateVariable5": {
        "id": "6c6eab39063fa3b72d98c82af60deb8a",
        "class": "UpdateVariable",
        "name": "Update variable - Clean and normalize domain input",
        "flows": {
          "incoming": "FROM_CreateVariable3_TO_UpdateVariable5",
          "outgoing": "FROM_UpdateVariable5_TO_VirusTotalDomainLookup"
        },
        "properties": {
          "WorkflowCustomVariable": {
            "cleaned_domain": "${data['domain'].contains('://')?data['domain'].split('://')[1].split('/')[0]:data['domain'].split('/')[0]}"
          }
        },
        "version_constraint": "~1"
      },
      "UpdateVariable6": {
        "id": "6c6eab39063fa3b72d98c82af60deb8a",
        "class": "UpdateVariable",
        "name": "Update variable - Build VirusTotal analysis comment",
        "flows": {
          "incoming": "FROM_status_code_is_equal_to_200___ok_TO_UpdateVariable6",
          "outgoing": "FROM_UpdateVariable6_TO_UpdateVariable7"
        },
        "properties": {
          "WorkflowCustomVariable": {
            "comment": "${data['WorkflowCustomVariable.comment'] + \"\\n\" + ((data['VirusTotalDomainLookup.body.data.attributes'] != null) ? ('VirusTotal Enrichment for ' + data['WorkflowCustomVariable.cleaned_domain'] + ': |~|\\n' +   (data['VirusTotalDomainLookup.body.data.attributes.total_votes.malicious'] != null && data['VirusTotalDomainLookup.body.data.attributes.total_votes.malicious'] >= 0 ? '- Malicious Votes: ' + string(data['VirusTotalDomainLookup.body.data.attributes.total_votes.malicious']) + ' |~|\\n' : '') +   (data['VirusTotalDomainLookup.body.data.attributes.total_votes.harmless'] != null && data['VirusTotalDomainLookup.body.data.attributes.total_votes.harmless'] >= 0 ? '- Harmless Votes: ' + string(data['VirusTotalDomainLookup.body.data.attributes.total_votes.harmless']) + ' |~|\\n' : '') +   (data['VirusTotalDomainLookup.body.data.attributes.registrar'] != null && data['VirusTotalDomainLookup.body.data.attributes.registrar'] != '' ? '- Registrar: ' + data['VirusTotalDomainLookup.body.data.attributes.registrar'] + ' |~|\\n' : '') +   (data['VirusTotalDomainLookup.body.data.attributes.creation_date'] != null && data['VirusTotalDomainLookup.body.data.attributes.creation_date'] >= 0 ? '- Creation Date: ' + cs.timestamp.format(timestamp(int(data['VirusTotalDomainLookup.body.data.attributes.creation_date'])), 'RFC822') + ' |~|\\n' : '') +   (data['VirusTotalDomainLookup.body.data.attributes.last_modification_date'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_modification_date'] >= 0 ? '- Last Modified: ' + cs.timestamp.format(timestamp(int(data['VirusTotalDomainLookup.body.data.attributes.last_modification_date'])), 'RFC822') + ' |~|\\n' : '') +   (data['VirusTotalDomainLookup.body.data.attributes.last_update_date'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_update_date'] >= 0 ? '- Last Updated: ' + cs.timestamp.format(timestamp(int(data['VirusTotalDomainLookup.body.data.attributes.last_update_date'])), 'RFC822') + \" |~|\\n\": '')) : '')}",
            "tags": "${data['WorkflowCustomVariable.tags']+((data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats'] != null) ? [\n  (data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.malicious'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.malicious'] >= 0) ? (\"VirusTotal:\" + data['WorkflowCustomVariable.cleaned_domain'] + \":malicious:\" + string(data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.malicious'])) : \"\",\n  (data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.suspicious'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.suspicious'] >= 0) ? (\"VirusTotal:\" + data['WorkflowCustomVariable.cleaned_domain'] + \":suspicious:\" + string(data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.suspicious'])) : \"\",\n  (data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.harmless'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.harmless'] >= 0) ? (\"VirusTotal:\" + data['WorkflowCustomVariable.cleaned_domain'] + \":harmless:\" + string(data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.harmless'])) : \"\",\n  (data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.undetected'] != null && data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.undetected'] >= 0) ? (\"VirusTotal:\" + data['WorkflowCustomVariable.cleaned_domain'] + \":undetected:\" + string(data['VirusTotalDomainLookup.body.data.attributes.last_analysis_stats.undetected'])) : \"\",\n  (data['VirusTotalDomainLookup.body.data.attributes.reputation'] != null && data['VirusTotalDomainLookup.body.data.attributes.reputation'] != \"\") ? (\"VirusTotal:\" + data['WorkflowCustomVariable.cleaned_domain'] + \":reputation:\" + string(data['VirusTotalDomainLookup.body.data.attributes.reputation'])) : \"\"\n].filter(tag, tag != \"\") : [])}"
          }
        },
        "version_constraint": "~1"
      },
      "UpdateVariable7": {
        "id": "6c6eab39063fa3b72d98c82af60deb8a",
        "class": "UpdateVariable",
        "name": "Update variable - Extract A record resolution IDs",
        "flows": {
