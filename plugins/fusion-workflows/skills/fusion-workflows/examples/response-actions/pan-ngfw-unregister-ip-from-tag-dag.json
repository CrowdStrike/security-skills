{
  "name": "PAN NGFW - Unregister IP from Tag (DAG)",
  "description": "Unregisters an IP address from a tag on a PAN NGFW firewall via the User-ID API, removing it from any Dynamic Address Group (DAG) that matches that tag. Use this to lift containment or blocklist enforcement previously applied through DAG tagging.",
  "model": {
    "trigger": {
      "name": "On demand",
      "outgoing_flow": "FROM_trigger_TO_UnregisterIPFromTag",
      "parameters": {
        "properties": {
          "FirewallIP": {
            "type": "string",
            "description": "IP address or hostname of the PAN NGFW management interface"
          },
          "TagName": {
            "type": "string",
            "description": "Tag to remove the IP from (e.g. malicious) \u2014 must match the tag used when the IP was registered"
          },
          "TargetIP": {
            "type": "string",
            "description": "IP address to unregister from the tag (e.g. 10.1.1.1)"
          }
        },
        "required": [
          "FirewallIP",
          "TagName",
          "TargetIP"
        ],
        "type": "object"
      },
      "trigger_type": "On demand"
    },
