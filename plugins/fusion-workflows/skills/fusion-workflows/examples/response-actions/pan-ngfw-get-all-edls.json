{
  "name": "PAN NGFW - Get All EDLs",
  "description": "Retrieves all External Dynamic List (EDL) objects configured on a PAN NGFW firewall for a given XPath scope (per-vsys or shared). Use this to audit available EDLs or identify the correct EDL name before performing blocklist or allowlist operations.",
  "model": {
    "trigger": {
      "name": "On demand",
      "outgoing_flow": "FROM_trigger_TO_GetAllEDLs",
      "parameters": {
        "properties": {
          "FirewallIP": {
            "type": "string",
            "description": "IP address or hostname of the PAN NGFW management interface"
          },
          "XPath": {
            "enum": [
              "/config/devices/entry[@name='localhost.localdomain']/vsys/entry[@name='vsys1']/external-list",
              "/config/shared/external-list"
            ],
            "type": "string",
            "description": "XPath scope to query: use vsys path for per-vsys EDLs, or shared path for EDLs shared across all vsys"
          }
        },
        "required": [
          "XPath",
          "FirewallIP"
        ],
        "type": "object"
      },
      "trigger_type": "On demand"
    },
    "flows": {
      "FROM_trigger_TO_GetAllEDLs": {
        "source": "trigger",
        "target": "GetAllEDLs",
        "condition": {}
      },
      "flow_611adb8b-8012-4eb8-aee9-2cb7578915fa": {
        "source": "GetAllEDLs",
        "target": "end",
        "condition": {}
      }
    },
