            "type": "string",
            "description": "Exact name of the EDL object on the firewall to add the exception to"
          },
          "EntryValue": {
            "type": "string",
            "description": "IP address, domain, or URL to add to the exception list (e.g. 1.2.3.4)"
          },
          "FirewallIP": {
            "type": "string",
            "description": "IP address or hostname of the PAN NGFW management interface"
          }
        },
        "required": [
